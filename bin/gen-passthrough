#!/usr/bin/env python3
r"""Generate config/copy-passthrough.conf — the per-key "type-to-exit" binds.

Why generated: in tmux copy-mode (vi), scrolling up traps you in a modal where
keystrokes are vi commands (/ search, g/G goto, : goto-line...). We want the
Ghostty-like feel: while scrolled up, any normal key snaps back to the live
prompt AND lands the character there. That needs one bind per printable char:

    bind -T copy-mode-vi 'K' send -X cancel \; send -l -- 'K'

`send -X cancel` leaves copy-mode (jump to live), then `send -l -- K` types the
literal char at the prompt. We use tmux's native in-config `\;` separator (the
same one used elsewhere in tmux.conf) — NOT a shell loop, which mangles the
separator across the sh/zsh layers.

KEEP = keys whose copy-mode meaning we preserve, so mouse + keyboard copy still
work: v/V begin a selection, y copies, q quits. (Arrows/Enter/Escape aren't
printable so they keep their defaults automatically.)

Run:  bin/gen-passthrough > config/copy-passthrough.conf
"""
import sys

KEEP = set("vVyq")


def quote(c: str) -> str:
    # Single-quote-wrap makes every char literal to tmux's config lexer
    # (# ; { } $ ` " \ all become literal). The lone exception is the single
    # quote itself, which we double-quote-wrap instead.
    return f'"{c}"' if c == "'" else f"'{c}'"


def main() -> int:
    out = [
        "# === GENERATED by bin/gen-passthrough — DO NOT EDIT BY HAND ===",
        "# copy-mode-vi 'type-to-exit': any printable key cancels copy-mode and",
        "# lands the literal char at the live prompt. Regenerate with:",
        "#   bin/gen-passthrough > config/copy-passthrough.conf",
        f"# Preserved copy keys (not overridden): {' '.join(sorted(KEEP))}",
    ]
    for i in range(33, 127):  # printable ASCII, excl. space (32) and DEL (127)
        c = chr(i)
        if c in KEEP:
            continue
        k = quote(c)
        out.append(f"bind -T copy-mode-vi {k} send -X cancel \\; send -l -- {k}")
    sys.stdout.write("\n".join(out) + "\n")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
